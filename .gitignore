# Original RingTaxi recordings (large files + personal data) — not for GitHub
media/

# Generated files (remuxed video, ~892 MB — can be regenerated from media/ with ffmpeg)
derived/

# Python
__pycache__/
*.pyc
.venv/

# Local Claude Code settings (machine-specific)
.claude/settings.local.json*

# Remembers the last media folder used by the folder picker (machine-specific)
.rnv-state.json

# Misc
*.log
.DS_Store
Thumbs.db

# Windows download metadata (appears when copying files into WSL)
*:Zone.Identifier
